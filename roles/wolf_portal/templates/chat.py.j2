#!/usr/bin/env python3
import re
import json
import hmac
import hashlib
import random
import sqlite3
from datetime import datetime
from http.server import BaseHTTPRequestHandler, HTTPServer

logfile     = "{{ live_chat_log_file }}"
_PASSWORD   = "{{ live_chat_password }}"
DB_PATH     = "{{ live_chat_dir }}/portal.db"
_GAME_PORT  = {{ etlegacy_game_port | default(27960) }}
_RCON_PASS  = "{{ etlegacy_rcon_password | default('') }}"

# Stateless token: HMAC-SHA256(password) — changing password auto-invalidates all tokens
VALID_TOKEN = hmac.new(
    b"et-live-chat-v1",
    _PASSWORD.encode("utf-8"),
    hashlib.sha256,
).hexdigest()

_CODENAMES = [
    "GHOST", "VIPER", "SHADOW", "PHANTOM", "COBRA", "EAGLE", "FALCON",
    "RAVEN", "HAWK", "STORM", "FROST", "BLADE", "TITAN", "CIPHER",
    "NOVA",  "APEX",  "IRON",   "LYNX",   "OMEGA", "TALON", "WRAITH",
    "FURY",  "GRIM",  "HAVOC",  "DUSK",   "PYRO",  "RIDGE", "SCOUT",
]

# ─── Database ─────────────────────────────────────────────────────────────────

def init_db():
    with sqlite3.connect(DB_PATH) as conn:
        conn.executescript("""
            PRAGMA foreign_keys = ON;
            CREATE TABLE IF NOT EXISTS matches (
                id         INTEGER PRIMARY KEY AUTOINCREMENT,
                title      TEXT    NOT NULL,
                match_date TEXT,
                team1      TEXT    NOT NULL DEFAULT 'ALLIES',
                team2      TEXT    NOT NULL DEFAULT 'AXIS',
                anonymous  INTEGER NOT NULL DEFAULT 0,
                created_by TEXT    NOT NULL,
                created_at TEXT    NOT NULL
            );
            CREATE TABLE IF NOT EXISTS signups (
                id         INTEGER PRIMARY KEY AUTOINCREMENT,
                match_id   INTEGER NOT NULL REFERENCES matches(id) ON DELETE CASCADE,
                nickname   TEXT    NOT NULL,
                codename   TEXT,
                side       INTEGER NOT NULL,
                joined_at  TEXT    NOT NULL,
                UNIQUE (match_id, nickname)
            );
        """)

def _db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    return conn

# ─── Auth ─────────────────────────────────────────────────────────────────────

def _check_bearer(handler) -> bool:
    auth = handler.headers.get("Authorization", "")
    if not auth.startswith("Bearer "):
        return False
    return hmac.compare_digest(auth[7:].strip(), VALID_TOKEN)

# ─── HTTP helpers ─────────────────────────────────────────────────────────────

def _json(handler, status, body) -> None:
    data = json.dumps(body, ensure_ascii=False).encode("utf-8")
    handler.send_response(status)
    handler.send_header("Content-Type", "application/json; charset=utf-8")
    handler.send_header("Content-Length", str(len(data)))
    handler.end_headers()
    try:
        handler.wfile.write(data)
    except (BrokenPipeError, ConnectionResetError):
        pass

def _read_body(handler) -> dict:
    n = int(handler.headers.get("Content-Length", 0))
    return json.loads(handler.rfile.read(n)) if n > 0 else {}

# ─── Log parsing ──────────────────────────────────────────────────────────────

_color_re = re.compile(r"\^\d")

def _clean(s: str) -> str:
    return _color_re.sub("", s)

def _decode_czech(raw: str) -> str:
    try:
        line = raw.encode("latin-1").decode("cp1250")
    except Exception:
        try:
            line = raw.encode("latin-1").decode("utf-8")
        except Exception:
            line = raw
    def _esc(m):
        try:
            return chr(int(m.group(1), 10))
        except Exception:
            return m.group(0)
    return re.sub(r"\\u\{([0-9]+)\}", _esc, line)

def parse_chat():
    output, current_day, current_map = [], None, None
    day_changed = map_changed = False
    try:
        with open(logfile, "r", encoding="latin-1", errors="ignore") as f:
            for raw in f:
                line = _decode_czech(raw)
                if "gametime:" in line:
                    try:
                        parts = line.split("gametime:", 1)[1].strip()
                        nd = datetime.strptime(parts, "%a %b %d %H:%M:%S %Y").strftime("%Y-%m-%d")
                        if nd != current_day:
                            current_day, day_changed = nd, True
                    except Exception:
                        pass
                if "InitGame:" in line and "map:" in line:
                    try:
                        nm = line.split("map:", 1)[1].strip().split()[0]
                        if nm != current_map:
                            current_map, map_changed = nm, True
                    except Exception:
                        pass
                    continue
                if " say: " in line:
                    try:
                        _, msg = line.split(" say: ", 1)
                        msg = _clean(msg.strip())
                        if day_changed:
                            output.append("=== DAY " + current_day + " ===")
                            day_changed = False
                        if map_changed:
                            output.append("--- MAP " + current_map + " ---")
                            map_changed = False
                        output.append(msg)
                    except Exception:
                        continue
    except FileNotFoundError:
        return ["Error: log file not found: " + logfile]
    return output[-400:]

def parse_gameinfo():
    """Return live game info: UDP player list + RCON team data + log kill feed."""
    import socket as _socket

    # ── UDP getstatus (no auth) ────────────────────────────────────────────
    players = []
    map_name = "N/A"
    gametype = ""
    server_online = False
    try:
        sock = _socket.socket(_socket.AF_INET, _socket.SOCK_DGRAM)
        sock.settimeout(2)
        sock.sendto(b'\xff\xff\xff\xffgetstatus', ("127.0.0.1", _GAME_PORT))
        data, _ = sock.recvfrom(8192)
        sock.close()
        text  = data[4:].decode("latin-1")
        lines = text.strip().split("\n")
        parts = lines[1].split("\\") if len(lines) > 1 else []
        cvars = {parts[i]: parts[i+1] for i in range(1, len(parts)-1, 2)}
        map_name = cvars.get("mapname", "N/A")
        gametype = cvars.get("g_gametype", "")
        server_online = True
        for line in lines[2:]:
            line = line.strip()
            if not line:
                continue
            m = re.match(r'(-?\d+)\s+(\d+)\s+"(.+)"', line)
            if m:
                players.append({
                    "name":  _clean(m.group(3)),
                    "score": int(m.group(1)),
                    "ping":  int(m.group(2)),
                    "team":  "",
                    "slot":  -1,
                })
    except Exception:
        try:
            sock.close()
        except Exception:
            pass

    # ── RCON: merge team + slot info ───────────────────────────────────────
    if server_online and players:
        teams = rcon_get_teams()
        for p in players:
            info = teams.get(p["name"])
            if info:
                p["team"] = info["team"]
                p["slot"] = info["slot"]

    # ── Log tail: kills and chat since last InitGame ───────────────────────
    kills = []
    chat  = []
    try:
        with open(logfile, "r", encoding="latin-1", errors="ignore") as f:
            lines = f.readlines()
        segment = []
        for raw in reversed(lines[-5000:]):
            segment.append(raw)
            if "InitGame:" in raw:
                break
        segment.reverse()

        _kill_re = re.compile(
            r"^\s*\d+\s+Kill:\s+\d+\s+\d+\s+\d+:\s+(.+?)\s+killed\s+(.+?)\s+by\s+(MOD_\S+)"
        )
        for raw in segment:
            line = _decode_czech(raw)
            km = _kill_re.match(line)
            if km:
                killer = _clean(km.group(1))
                victim = _clean(km.group(2))
                weapon = km.group(3).replace("MOD_", "").replace("_", " ")
                kills.append({"killer": killer, "victim": victim, "weapon": weapon})
                continue
            if " say: " in line:
                try:
                    before, msg = line.split(" say: ", 1)
                    name = _clean(before.strip().split(None, 1)[-1])
                    chat.append({"name": name, "msg": _clean(msg.strip())})
                except Exception:
                    pass
    except FileNotFoundError:
        pass

    return {
        "online":         server_online,
        "map":            map_name,
        "gametype":       gametype,
        "players":        players,
        "kills":          kills[-20:],
        "recent_matches": parse_recent_matches(),
    }

def parse_recent_matches():
    """Return last N completed matches from the server log."""
    results = []
    current_map = None
    try:
        with open(logfile, "r", encoding="latin-1", errors="ignore") as f:
            lines = f.readlines()
        # Scan last 20000 lines for map/exit/scores
        pending_map = None
        pending_exit = None
        for raw in lines[-20000:]:
            line = raw.strip()
            # Track current map from "N map: mapname" lines (after InitGame)
            m = re.match(r"^\s*\d+\s+map:\s+(\S+)", line)
            if m:
                pending_map = m.group(1)
                continue
            # Exit reason
            m = re.match(r"^\s*\d+\s+Exit:\s+(.+)", line)
            if m:
                pending_exit = m.group(1).strip()
                continue
            # Scores follow immediately after Exit
            m = re.match(r"^\s*\d+\s+axis:(\d+)\s+allies:(\d+)", line)
            if m and pending_exit is not None and pending_map:
                results.append({
                    "map":    pending_map,
                    "exit":   pending_exit,
                    "axis":   int(m.group(1)),
                    "allies": int(m.group(2)),
                })
                pending_exit = None
    except FileNotFoundError:
        pass
    # Return last 8, newest first
    return list(reversed(results[-8:]))

# ─── RCON ─────────────────────────────────────────────────────────────────────

def rcon_query(command, timeout=1.0):
    """Send one RCON UDP command, return first response packet text or ''."""
    import socket as _sock
    if not _RCON_PASS:
        return ""
    pkt = (b'\xff\xff\xff\xffrcon ' +
           _RCON_PASS.encode("latin-1") + b' ' +
           command.encode("utf-8"))
    s = _sock.socket(_sock.AF_INET, _sock.SOCK_DGRAM)
    s.settimeout(timeout)
    try:
        s.sendto(pkt, ("127.0.0.1", _GAME_PORT))
        data, _ = s.recvfrom(16384)
        text = data.decode("latin-1", errors="replace")
        if text.startswith("\xff\xff\xff\xff"):
            text = text[4:]
        if text.startswith("print\n"):
            text = text[6:]
        return text
    except Exception:
        return ""
    finally:
        try:
            s.close()
        except Exception:
            pass

_RCON_STATUS_RE = re.compile(
    r"^\s*(\d+)\s+(-?\d+)\s+(\d+)\s+(.+?)\s{2,}\d+\s+\S+",
    re.MULTILINE,
)

import time as _time
_teams_cache = {"ts": 0.0, "data": {}}

def rcon_get_teams():
    """Return dict of cleaned_name -> {slot, team} with 8-second cache."""
    global _teams_cache
    now = _time.time()
    if now - _teams_cache["ts"] < 8:
        return _teams_cache["data"]
    raw = rcon_query("status", timeout=1.5)
    result = {}
    for m in _RCON_STATUS_RE.finditer(raw):
        slot = int(m.group(1))
        name = _clean(m.group(4).strip())
        du   = rcon_query(f"dumpuser {slot}", timeout=0.5)
        tm   = re.search(r'\\team\\(\w+)', du) or re.search(r'\bteam\s+(\w+)', du)
        result[name] = {
            "slot": slot,
            "team": tm.group(1).upper() if tm else "",
        }
    _teams_cache = {"ts": now, "data": result}
    return result

# ─── Match data layer ─────────────────────────────────────────────────────────

def _pick_codename(match_id, used_set):
    available = [c for c in _CODENAMES if c not in used_set]
    if not available:
        n = 1
        while ("AGENT-%02d" % n) in used_set:
            n += 1
        return "AGENT-%02d" % n
    return random.choice(available)

def get_matches(caller_callsign=""):
    with _db() as conn:
        rows = conn.execute(
            "SELECT id, title, match_date, team1, team2, anonymous, created_by, created_at "
            "FROM matches ORDER BY created_at DESC"
        ).fetchall()
        result = []
        for row in rows:
            anon = bool(row["anonymous"])
            srows = conn.execute(
                "SELECT nickname, codename, side FROM signups WHERE match_id=? ORDER BY joined_at",
                (row["id"],)
            ).fetchall()
            signups = []
            for s in srows:
                display = s["codename"] if (anon and s["codename"]) else s["nickname"]
                is_you  = (s["nickname"] == caller_callsign) if caller_callsign else False
                signups.append({"nickname": display, "side": s["side"], "is_you": is_you})
            result.append({
                "id":         row["id"],
                "title":      row["title"],
                "match_date": row["match_date"],
                "team1":      row["team1"],
                "team2":      row["team2"],
                "anonymous":  anon,
                "created_by": row["created_by"],
                "created_at": row["created_at"],
                "signups":    signups,
            })
        return result

def create_match(title, match_date, team1, team2, anonymous, created_by):
    with _db() as conn:
        cur = conn.execute(
            "INSERT INTO matches (title, match_date, team1, team2, anonymous, created_by, created_at) "
            "VALUES (?,?,?,?,?,?,?)",
            (title, match_date or "", team1 or "ALLIES", team2 or "AXIS",
             1 if anonymous else 0, created_by or "unknown",
             datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%S"))
        )
        conn.commit()
        return cur.lastrowid

def delete_match(match_id):
    with _db() as conn:
        conn.execute("DELETE FROM matches WHERE id=?", (match_id,))
        conn.commit()

def join_match(match_id, nickname, side):
    with _db() as conn:
        # Check if match is anonymous and pick codename if needed
        row = conn.execute("SELECT anonymous FROM matches WHERE id=?", (match_id,)).fetchone()
        if not row:
            raise ValueError("match not found")
        codename = None
        if row["anonymous"]:
            used = {s["codename"] for s in conn.execute(
                "SELECT codename FROM signups WHERE match_id=? AND codename IS NOT NULL",
                (match_id,)
            ).fetchall()}
            codename = _pick_codename(match_id, used)
        conn.execute(
            "INSERT OR REPLACE INTO signups (match_id, nickname, codename, side, joined_at) "
            "VALUES (?,?,?,?,?)",
            (match_id, nickname, codename, side,
             datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%S"))
        )
        conn.commit()

def leave_match(match_id, nickname):
    with _db() as conn:
        conn.execute(
            "DELETE FROM signups WHERE match_id=? AND nickname=?",
            (match_id, nickname)
        )
        conn.commit()

# ─── Request handler ──────────────────────────────────────────────────────────

_RE_MATCH      = re.compile(r"^/api/matches/(\d+)$")
_RE_MATCH_JOIN = re.compile(r"^/api/matches/(\d+)/join$")
_RE_MATCH_LEAVE= re.compile(r"^/api/matches/(\d+)/leave$")

class Handler(BaseHTTPRequestHandler):

    def _guarded(self, fn):
        if not _check_bearer(self):
            _json(self, 401, {"error": "unauthorized"})
            return
        try:
            fn()
        except Exception as exc:
            _json(self, 500, {"error": str(exc)})

    def do_POST(self):
        p = self.path
        if p == "/chat/login":
            self._login(); return
        if p == "/api/matches":
            self._guarded(self._create_match); return
        if p == "/api/admin":
            self._guarded(self._admin_action); return
        m = _RE_MATCH_JOIN.match(p)
        if m:
            mid = int(m.group(1))
            self._guarded(lambda: self._join_match(mid)); return
        m = _RE_MATCH_LEAVE.match(p)
        if m:
            mid = int(m.group(1))
            self._guarded(lambda: self._leave_match(mid)); return
        _json(self, 404, {"error": "not found"})

    def do_GET(self):
        p = self.path
        if p == "/chat/api":
            self._guarded(self._chat); return
        if p == "/api/matches":
            self._guarded(self._list_matches); return
        if p == "/api/gameinfo":
            self._guarded(self._gameinfo); return
        if p == "/api/status":
            self._guarded(self._server_status); return
        self.send_response(404); self.end_headers()

    def do_DELETE(self):
        m = _RE_MATCH.match(self.path)
        if m:
            mid = int(m.group(1))
            self._guarded(lambda: self._delete_match(mid)); return
        _json(self, 404, {"error": "not found"})

    # ── Route handlers ────────────────────────────────────────────────────

    def _login(self):
        try:
            body = _read_body(self)
        except Exception:
            _json(self, 400, {"error": "invalid request"}); return
        pw = body.get("password", "")
        if hmac.compare_digest(pw.encode("utf-8"), _PASSWORD.encode("utf-8")):
            _json(self, 200, {"token": VALID_TOKEN})
        else:
            _json(self, 401, {"error": "invalid password"})

    def _chat(self):
        msgs = parse_chat()
        data = json.dumps(msgs, ensure_ascii=False).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        try:
            self.wfile.write(data)
        except (BrokenPipeError, ConnectionResetError):
            pass

    def _list_matches(self):
        caller = self.headers.get("X-Callsign", "")
        _json(self, 200, get_matches(caller))

    def _create_match(self):
        body = _read_body(self)
        title = (body.get("title") or "").strip()
        if not title:
            _json(self, 400, {"error": "title required"}); return
        mid = create_match(
            title=title,
            match_date=body.get("match_date", ""),
            team1=body.get("team1", "ALLIES"),
            team2=body.get("team2", "AXIS"),
            anonymous=body.get("anonymous", False),
            created_by=body.get("created_by", "unknown"),
        )
        _json(self, 201, {"id": mid})

    def _delete_match(self, match_id):
        delete_match(match_id)
        _json(self, 200, {"ok": True})

    def _join_match(self, match_id):
        body = _read_body(self)
        nickname = (body.get("nickname") or "").strip()
        side = body.get("side", 1)
        if not nickname:
            _json(self, 400, {"error": "nickname required"}); return
        join_match(match_id, nickname, int(side))
        _json(self, 200, {"ok": True})

    def _leave_match(self, match_id):
        body = _read_body(self)
        nickname = (body.get("nickname") or "").strip()
        if not nickname:
            _json(self, 400, {"error": "nickname required"}); return
        leave_match(match_id, nickname)
        _json(self, 200, {"ok": True})

    def _gameinfo(self):
        _json(self, 200, parse_gameinfo())

    def _admin_action(self):
        body   = _read_body(self)
        action = body.get("action", "")
        if action == "kick":
            try:
                slot = int(body.get("slot", -1))
            except (TypeError, ValueError):
                slot = -1
            if slot < 0:
                _json(self, 400, {"error": "slot required"}); return
            result = rcon_query(f"clientkick {slot}", timeout=2.0)
            _json(self, 200, {"ok": True, "result": result.strip()})
        elif action == "map":
            mapname = re.sub(r"[^\w\-]", "", (body.get("map") or "").strip())
            if not mapname:
                _json(self, 400, {"error": "invalid map name"}); return
            result = rcon_query(f"map {mapname}", timeout=2.0)
            _json(self, 200, {"ok": True, "result": result.strip()})
        else:
            _json(self, 400, {"error": "unknown action"})

    def _server_status(self):
        gi = parse_gameinfo()
        _json(self, 200, {"map": gi["map"], "players": [p["name"] for p in gi["players"]]})

    def log_message(self, fmt, *args):
        pass

if __name__ == "__main__":
    init_db()
    server = HTTPServer(("127.0.0.1", {{ live_chat_port }}), Handler)
    print("Wolf's Lair backend on http://127.0.0.1:{{ live_chat_port }}")
    server.serve_forever()
