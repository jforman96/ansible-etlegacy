<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/chat/favicon.ico" type="image/x-icon">
<title>WOLF:ET · Operations Center</title>
<style>

:root {
  --g:      #00FF00;
  --g-hi:   #66FF66;
  --g-mid:  #00CC00;
  --g-dim:  #009900;
  --g-dark: #005500;
  --g-mute: #003300;
  --bg:     #040c04;
  --bg-p:   #071207;
  --bg-c:   #0b180b;
  --bd:     #1a4a1a;
  --bd-hi:  #007700;
  --tx:     #00FF00;
  --tx-mid: #00CC00;
  --tx-dim: #009900;
  --tx-lo:  #004400;
  --red:    #ff4444;
  --font:   'Courier New', 'Lucida Console', monospace;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html, body { height: 100%; }

body {
  background-color: var(--bg);
  color: var(--tx-mid);
  font-family: var(--font);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-image: repeating-linear-gradient(
    0deg,
    rgba(0,0,0,0.12) 0px, rgba(0,0,0,0.12) 1px,
    transparent 1px, transparent 3px
  );
}

.hidden { display: none !important; }

::-webkit-scrollbar       { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--g-dark); border: 1px solid var(--bd); }
::-webkit-scrollbar-thumb:hover { background: var(--g-mute); }

@keyframes blink   { 0%,49%,100%{opacity:1} 50%,99%{opacity:0} }
@keyframes pulse   { 0%,100%{opacity:1} 50%{opacity:.3} }
@keyframes fadein  { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
@keyframes glow    { 0%,100%{text-shadow:0 0 8px rgba(0,255,0,.5)} 50%{text-shadow:0 0 20px rgba(0,255,0,.9),0 0 40px rgba(0,255,0,.3)} }

/* ── Header ─────────────────────────────────────────── */
.p-header {
  background: var(--bg-p);
  border-bottom: 1px solid var(--bd-hi);
  padding: 0 28px;
  height: 54px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 0 24px rgba(0,255,0,.06), 0 2px 0 rgba(0,255,0,.08);
}

.p-header-l { display: flex; align-items: center; gap: 14px; }

.p-logo {
  width: 28px; height: 28px;
  border: 1px solid var(--bd-hi);
  filter: brightness(.8) sepia(1) hue-rotate(80deg) saturate(5);
}

.p-title {
  font-size: 14px;
  font-weight: bold;
  letter-spacing: 3px;
  color: var(--g);
  text-shadow: 0 0 12px rgba(0,255,0,.5);
}

.p-header-r { display: flex; align-items: center; gap: 12px; }

.p-online {
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--g-dim);
  display: flex;
  align-items: center;
  gap: 7px;
}
.p-online::before {
  content: '';
  display: inline-block;
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--g);
  box-shadow: 0 0 8px var(--g);
  animation: pulse 2s ease-in-out infinite;
}

/* ── Buttons ─────────────────────────────────────────── */
.btn {
  background: transparent;
  color: var(--g-dim);
  border: 1px solid var(--bd);
  padding: 6px 16px;
  font-family: var(--font);
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 2px;
  cursor: pointer;
  transition: all .15s ease;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.btn:hover {
  color: var(--g);
  border-color: var(--g-dim);
  background: rgba(0,255,0,.05);
  box-shadow: 0 0 10px rgba(0,255,0,.1);
}
.btn.is-active {
  color: var(--g);
  border-color: var(--g-mid);
  background: var(--g-dark);
}

/* ════════════════════════════════════════════════════════
   LOGIN
   ════════════════════════════════════════════════════════ */
#loginScreen {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.login-wrap {
  width: 360px;
  border: 1px solid var(--bd-hi);
  background: var(--bg-c);
  box-shadow: 0 0 80px rgba(0,255,0,.06);
  animation: fadein .4s ease;
}

.login-top {
  border-bottom: 1px solid var(--bd);
  padding: 30px 32px 26px;
  text-align: center;
}

.login-logo-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin-bottom: 12px;
}

.login-logo-img {
  width: 38px; height: 38px;
  border: 1px solid var(--bd-hi);
  filter: brightness(.8) sepia(1) hue-rotate(80deg) saturate(5);
}

.login-heading {
  font-size: 26px;
  letter-spacing: 5px;
  color: var(--g);
  font-weight: bold;
  text-shadow: 0 0 16px rgba(0,255,0,.6);
  animation: glow 3s ease-in-out infinite;
}

.login-heading .cur { animation: blink 1s step-end infinite; }

.login-sub {
  font-size: 9px;
  letter-spacing: 4px;
  color: var(--tx-dim);
  margin-top: 6px;
}

.login-body { padding: 26px 32px 30px; }

#bootSeq {
  font-size: 11px;
  color: var(--tx-dim);
  line-height: 2.1;
  min-height: 66px;
  margin-bottom: 22px;
}

#bootSeq .bl { display: flex; justify-content: space-between; gap: 12px; }
#bootSeq .ok { color: var(--g-dim); }

#loginForm { display: flex; flex-direction: column; gap: 16px; }

.field-lbl {
  display: block;
  font-size: 10px;
  letter-spacing: 3px;
  color: var(--tx-dim);
  margin-bottom: 7px;
}

.field-inp {
  width: 100%;
  background: var(--bg);
  color: var(--g);
  border: 1px solid var(--bd-hi);
  padding: 10px 14px;
  font-family: var(--font);
  font-size: 14px;
  letter-spacing: 2px;
  outline: none;
  transition: border-color .15s, box-shadow .15s;
}
.field-inp:focus {
  border-color: var(--g);
  box-shadow: 0 0 12px rgba(0,255,0,.2), inset 0 0 8px rgba(0,255,0,.05);
}

.login-btn {
  width: 100%;
  padding: 12px;
  background: var(--g-dark);
  color: var(--g);
  border: 1px solid var(--g-mid);
  font-family: var(--font);
  font-size: 12px;
  font-weight: bold;
  letter-spacing: 4px;
  cursor: pointer;
  transition: all .15s ease;
  text-shadow: 0 0 6px rgba(0,255,0,.6);
}
.login-btn:hover {
  background: var(--g-mute);
  box-shadow: 0 0 20px rgba(0,255,0,.18);
}

.login-err {
  font-size: 10px;
  color: var(--red);
  letter-spacing: 1px;
  text-align: center;
  padding: 8px 12px;
  border: 1px solid rgba(255,68,68,.35);
  background: rgba(255,68,68,.06);
  display: none;
}
.login-err.show { display: block; }

/* ════════════════════════════════════════════════════════
   HUB
   ════════════════════════════════════════════════════════ */
#hubScreen {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  animation: fadein .3s ease;
}

.hub-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32px 28px 24px;
  gap: 28px;
}

.hub-label {
  font-size: 10px;
  letter-spacing: 5px;
  color: var(--tx-dim);
  text-align: center;
}

.hub-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  max-width: 900px;
  width: 100%;
}

@media (max-width: 680px) {
  .hub-grid { grid-template-columns: 1fr; max-width: 380px; }
}

.hub-card {
  position: relative;
  border: 1px solid var(--bd);
  background: var(--bg-c);
  padding: 32px 28px 28px;
  display: flex;
  flex-direction: column;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
  transition: border-color .2s, background .2s, box-shadow .2s;
  overflow: hidden;
  min-height: 280px;
}

.hub-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 3px;
  background: var(--bd);
  transition: background .2s, box-shadow .2s;
}

.hub-card:hover {
  border-color: var(--g-dim);
  background: #0d200d;
  box-shadow: 0 0 32px rgba(0,255,0,.08), inset 0 0 24px rgba(0,255,0,.03);
}
.hub-card:hover::before {
  background: var(--g);
  box-shadow: 0 0 12px var(--g), 0 0 24px rgba(0,255,0,.4);
}
.hub-card:active { background: rgba(0,255,0,.06); }

.card-num {
  font-size: 9px;
  letter-spacing: 4px;
  color: var(--tx-lo);
  margin-bottom: 22px;
}

.card-icon {
  font-size: 36px;
  margin-bottom: 18px;
  line-height: 1;
  color: var(--g);
  text-shadow: 0 0 10px rgba(0,255,0,.5);
}

.card-name {
  font-size: 22px;
  font-weight: bold;
  letter-spacing: 4px;
  color: var(--g);
  text-shadow: 0 0 8px rgba(0,255,0,.4);
  margin-bottom: 14px;
}

.card-body {
  font-size: 12px;
  letter-spacing: 1px;
  color: var(--tx-mid);
  line-height: 1.9;
  flex: 1;
  margin-bottom: 26px;
}

.card-cta {
  font-size: 10px;
  letter-spacing: 3px;
  color: var(--g-dim);
  border-top: 1px solid var(--bd);
  padding-top: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: color .15s, border-color .15s;
}
.card-cta .arr { transition: transform .2s; }
.hub-card:hover .card-cta { color: var(--g); border-color: var(--bd-hi); }
.hub-card:hover .card-cta .arr { transform: translateX(4px); }

.hub-footer {
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--tx-lo);
  text-align: center;
}

/* ════════════════════════════════════════════════════════
   CHAT
   ════════════════════════════════════════════════════════ */
#chatScreen {
  display: flex;
  flex-direction: column;
  height: 100vh;
  animation: fadein .25s ease;
}

#chatFeed {
  flex: 1;
  background: var(--bg);
  padding: 16px 22px;
  overflow-y: auto;
  font-size: 13px;
  line-height: 1.8;
}

.msg {
  display: flex;
  padding: 2px 8px;
  border-left: 2px solid transparent;
  transition: background .1s, border-color .1s;
}
.msg:hover { background: rgba(0,255,0,.05); border-left-color: var(--bd-hi); }

.nick {
  font-weight: bold;
  min-width: 140px;
  flex-shrink: 0;
  margin-right: 10px;
  text-shadow: 0 0 4px rgba(0,255,0,.35);
}

.txt { color: var(--tx-mid); flex: 1; word-break: break-word; }

.sep {
  margin: 14px 0 8px;
  padding: 6px 14px;
  font-size: 10px;
  letter-spacing: 2px;
  text-align: center;
}
.sep.day {
  border: 1px solid var(--bd-hi);
  background: var(--bg-c);
  color: var(--g);
  text-shadow: 0 0 6px rgba(0,255,0,.4);
}
.sep.map {
  border-bottom: 1px dashed var(--bd);
  color: var(--tx-dim);
}

/* ════════════════════════════════════════════════════════
   CONNECT
   ════════════════════════════════════════════════════════ */
#streamScreen {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  animation: fadein .25s ease;
}

.stream-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32px 24px;
}

.stream-card {
  width: 100%;
  max-width: 720px;
  border: 1px solid var(--bd-hi);
  background: var(--bg-c);
  box-shadow: 0 0 48px rgba(0,0,0,.5);
}

.stream-card-hd {
  border-bottom: 1px solid var(--bd);
  padding: 18px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stream-card-hd-l .s-tag {
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--tx-dim);
  margin-bottom: 5px;
}

.stream-card-hd-l h3 {
  font-size: 16px;
  letter-spacing: 3px;
  color: var(--g);
  text-shadow: 0 0 8px rgba(0,255,0,.4);
}

/* Video player */
.video-wrap {
  background: #000;
  position: relative;
  aspect-ratio: 16/9;
  border-bottom: 1px solid var(--bd);
}

.video-wrap video {
  width: 100%;
  height: 100%;
  display: block;
}

.no-stream {
  aspect-ratio: 16/9;
  background: #000;
  border-bottom: 1px solid var(--bd);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  color: var(--tx-dim);
}

.no-stream .ns-icon { font-size: 48px; opacity: .4; }
.no-stream .ns-title {
  font-size: 13px;
  letter-spacing: 4px;
  color: var(--g-dark);
}
.no-stream .ns-sub {
  font-size: 9px;
  letter-spacing: 2px;
  color: var(--tx-lo);
}

.stream-card-bd {
  padding: 22px 28px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.info-table {
  background: var(--bg);
  border: 1px solid var(--bd);
  padding: 14px 18px;
  display: grid;
  grid-template-columns: 96px 1fr;
  gap: 8px 0;
}
.i-lbl { font-size: 10px; letter-spacing: 1px; color: var(--tx-dim); }
.i-val { font-size: 12px; color: var(--g); font-weight: bold; letter-spacing: 1px; }

.launch-btn {
  display: block;
  width: 100%;
  padding: 14px;
  background: var(--g-dark);
  color: var(--g);
  border: 1px solid var(--g-mid);
  text-align: center;
  font-family: var(--font);
  font-size: 12px;
  font-weight: bold;
  letter-spacing: 3px;
  cursor: pointer;
  text-decoration: none;
  transition: all .2s ease;
  text-shadow: 0 0 8px rgba(0,255,0,.6);
}
.launch-btn:hover {
  background: var(--g-mute);
  box-shadow: 0 0 24px rgba(0,255,0,.14);
}

.stream-note {
  font-size: 10px;
  color: var(--tx-dim);
  line-height: 1.9;
  border-top: 1px dashed var(--g-dark);
  padding-top: 16px;
}
.stream-note a { color: var(--g-dim); text-decoration: underline; }
.stream-note code {
  color: var(--g);
  background: var(--bg);
  padding: 2px 6px;
  border: 1px solid var(--bd);
  font-family: var(--font);
}

</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════
     LOGIN
     ═══════════════════════════════════════════════ -->
<div id="loginScreen">
  <div class="login-wrap">
    <div class="login-top">
      <div class="login-logo-row">
        <img class="login-logo-img"
             src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRA_p8Ykuu2HCz1n1M0li_q14jRys2-TwSMyg&s"
             alt="ET:Legacy">
        <div class="login-heading">WOLF:ET<span class="cur">█</span></div>
      </div>
      <div class="login-sub">OPERATIONS CENTER</div>
    </div>
    <div class="login-body">
      <div id="bootSeq"></div>
      <form id="loginForm" style="display:none">
        <div>
          <label class="field-lbl" for="pwdInput">ACCESS CODE</label>
          <input class="field-inp" id="pwdInput" type="password"
                 placeholder="············" autocomplete="current-password" required>
        </div>
        <button class="login-btn" type="submit">[ AUTHENTICATE ]</button>
        <div class="login-err" id="loginErr">! ACCESS DENIED</div>
      </form>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════
     HUB
     ═══════════════════════════════════════════════ -->
<div id="hubScreen" class="hidden">
  <header class="p-header">
    <div class="p-header-l">
      <img class="p-logo"
           src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRA_p8Ykuu2HCz1n1M0li_q14jRys2-TwSMyg&s"
           alt="ET:Legacy">
      <span class="p-title">WOLF:ET · OPS CENTER</span>
    </div>
    <div class="p-header-r">
      <span class="p-online">SERVER ONLINE</span>
      <button class="btn" onclick="logout()">[ LOGOUT ]</button>
    </div>
  </header>

  <div class="hub-body">
    <div class="hub-label">SELECT SECTION</div>

    <div class="hub-grid">

      <div class="hub-card" onclick="showSection('chat')">
        <div class="card-num">SECTION · 01</div>
        <div class="card-icon">◉</div>
        <div class="card-name">COMMS</div>
        <div class="card-body">
          Live in-game chat feed pulled
          directly from the server log.
          Auto-refreshes every 2.5 seconds.
        </div>
        <div class="card-cta">ENTER <span class="arr">▶</span></div>
      </div>

      <div class="hub-card" onclick="showSection('connect')">
        <div class="card-num">SECTION · 02</div>
        <div class="card-icon">◈</div>
        <div class="card-name">CONNECT</div>
        <div class="card-body">
          Direct server access. One click to
          launch ET:Legacy and join
          {{ etlegacy_server_name | default('myserver.example.com') }}.
        </div>
        <div class="card-cta">DEPLOY <span class="arr">▶</span></div>
      </div>

      <a class="hub-card" href="https://sites.google.com/view/wolf2026" target="_blank" rel="noopener">
        <div class="card-num">SECTION · 03</div>
        <div class="card-icon">◇</div>
        <div class="card-name">BRIEFING</div>
        <div class="card-body">
          Event schedules, upcoming matches,
          team announcements and
          mission planning.
        </div>
        <div class="card-cta">ACCESS <span class="arr">▶</span></div>
      </a>

    </div>

    <div class="hub-footer">ET:LEGACY · {{ etlegacy_server_name | default('myserver.example.com') }}</div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════
     CHAT
     ═══════════════════════════════════════════════ -->
<div id="chatScreen" class="hidden">
  <header class="p-header">
    <div class="p-header-l">
      <img class="p-logo"
           src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRA_p8Ykuu2HCz1n1M0li_q14jRys2-TwSMyg&s"
           alt="ET:Legacy">
      <span class="p-title">COMMS · LIVE CHAT</span>
    </div>
    <div class="p-header-r">
      <span id="chatStatus" class="p-online">LIVE</span>
      <button class="btn" id="censorBtn">CENSOR OFF</button>
      <button class="btn" onclick="showSection('hub')">◀ MENU</button>
    </div>
  </header>
  <div id="chatFeed">INITIALIZING...</div>
</div>

<!-- ═══════════════════════════════════════════════
     CONNECT
     ═══════════════════════════════════════════════ -->
<div id="connectScreen" class="hidden">
  <header class="p-header">
    <div class="p-header-l">
      <img class="p-logo"
           src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRA_p8Ykuu2HCz1n1M0li_q14jRys2-TwSMyg&s"
           alt="ET:Legacy">
      <span class="p-title">CONNECT · SERVER ACCESS</span>
    </div>
    <div class="p-header-r">
      <button class="btn" onclick="showSection('hub')">◀ MENU</button>
    </div>
  </header>
  <div class="stream-body">
    <div class="stream-card">

      <div class="stream-card-hd">
        <div class="stream-card-hd-l">
          <div class="s-tag">SECTION 02 · DIRECT SERVER ACCESS</div>
          <h3>ET:LEGACY CZ</h3>
        </div>
        <span class="p-online">ONLINE</span>
      </div>

      <div class="stream-card-bd">
        <div class="info-table">
          <span class="i-lbl">HOST</span>      <span class="i-val">{{ etlegacy_server_name | default('myserver.example.com') }}</span>
          <span class="i-lbl">PORT</span>      <span class="i-val">{{ etlegacy_port | default(27960) }}</span>
          <span class="i-lbl">GAME</span>      <span class="i-val">ET:LEGACY v{{ etlegacy_version | default('2.83') }}</span>
{% if etlegacy_password is defined and etlegacy_password %}
          <span class="i-lbl">PASSWORD</span> <span class="i-val">{{ etlegacy_password }}</span>
{% endif %}
        </div>

        <a class="launch-btn"
           href="etl://{{ etlegacy_server_name | default('myserver.example.com') }}:{{ etlegacy_port | default(27960) }}{% if etlegacy_password is defined and etlegacy_password %}?password={{ etlegacy_password }}{% endif %}">
          ▶ LAUNCH ET:LEGACY &amp; CONNECT
        </a>

        <div class="stream-note">
          Clicking the button opens ET:Legacy and connects directly to the server.<br>
          Requires <a href="https://www.etlegacy.com/download" target="_blank" rel="noopener">ET:Legacy v2.83+</a> installed on your machine.<br><br>
          Manual connect via in-game console:&nbsp;
          <code>/connect {{ etlegacy_server_name | default('myserver.example.com') }}:{{ etlegacy_port | default(27960) }}</code>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
'use strict';

const API_LOGIN = '/chat/login';
const API_CHAT  = '/chat/api';

const getToken   = () => { try { return sessionStorage.getItem('w_tok'); } catch { return null; } };
const setToken   = t  => { try { sessionStorage.setItem('w_tok', t); } catch {} };
const clearToken = () => { try { sessionStorage.removeItem('w_tok'); } catch {} };
const authHdr    = t  => ({ Authorization: 'Bearer ' + t });

let authToken    = null;
let chatInterval = null;
let lastData     = null;
let censored     = false;
let scrollLocked = false;
let chatSetup    = false;

const SCREENS = { login:'loginScreen', hub:'hubScreen', chat:'chatScreen', connect:'connectScreen' };

function showSection(name) {
  Object.values(SCREENS).forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('hidden', id !== SCREENS[name]);
  });
  if (name === 'chat') {
    setupChat();
    loadChat();
    if (!chatInterval) chatInterval = setInterval(loadChat, 2500);
  } else {
    if (chatInterval) { clearInterval(chatInterval); chatInterval = null; }
  }
}

/* ── login ──────────────────────────────────────────── */
async function handleLogin(e) {
  e.preventDefault();
  const inp = document.getElementById('pwdInput');
  const err = document.getElementById('loginErr');
  try {
    const res = await fetch(API_LOGIN, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: inp?.value || '' }),
      signal: AbortSignal.timeout(8000),
    });
    if (res.status === 401) { err.classList.add('show'); inp.value = ''; inp.focus(); return; }
    if (!res.ok) { err.textContent = '! SERVER ERROR ' + res.status; err.classList.add('show'); return; }
    const { token } = await res.json();
    setToken(token); authToken = token;
    err.classList.remove('show'); err.textContent = '! ACCESS DENIED';
    showSection('hub');
  } catch { err.textContent = '! CONNECTION ERROR'; err.classList.add('show'); }
}

function logout() {
  clearToken(); authToken = null;
  if (chatInterval) { clearInterval(chatInterval); chatInterval = null; }
  lastData = null; chatSetup = false;
  showSection('login');
  document.getElementById('bootSeq').innerHTML = '';
  bootSequence();
}

function sessionExpired() {
  clearToken(); authToken = null;
  if (chatInterval) { clearInterval(chatInterval); chatInterval = null; }
  showSection('login');
  const err = document.getElementById('loginErr');
  err.textContent = '! SESSION EXPIRED — RE-AUTHENTICATE';
  err.classList.add('show');
  document.getElementById('bootSeq').innerHTML = '';
  document.getElementById('loginForm').style.display = '';
  document.getElementById('pwdInput')?.focus();
}

/* ── init ───────────────────────────────────────────── */
(async function init() {
  const tok = getToken();
  if (tok) {
    try {
      const res = await fetch(API_CHAT, { headers: authHdr(tok), signal: AbortSignal.timeout(5000) });
      if (res.ok) { authToken = tok; showSection('hub'); return; }
    } catch {}
    clearToken();
  }
  bootSequence();
})();

/* ── boot sequence ──────────────────────────────────── */
function bootSequence() {
  const el = document.getElementById('bootSeq');
  const form = document.getElementById('loginForm');
  if (!el || !form) { if (form) form.style.display = ''; return; }
  el.style.display = ''; form.style.display = 'none'; el.innerHTML = '';

  const lines = [
    { t: 'ETLEGACY SERVER v2.83 ..........', ok: 'ONLINE' },
    { t: 'GAME LOG STREAM .................', ok: 'OK'     },
    { t: 'SECURE CHANNEL ..................', ok: 'READY'  },
  ];
  let i = 0;
  (function next() {
    if (i >= lines.length) {
      setTimeout(() => {
        const ls = document.getElementById('loginScreen');
        if (ls && !ls.classList.contains('hidden')) {
          el.style.display = 'none'; form.style.display = '';
          document.getElementById('pwdInput')?.focus();
        }
      }, 300);
      return;
    }
    const { t, ok } = lines[i++];
    const s = document.createElement('span'); s.className = 'bl';
    s.innerHTML = '<span>' + t + '</span><span class="ok">' + ok + '</span>';
    el.appendChild(s);
    setTimeout(next, 380);
  })();
}

/* ── chat ───────────────────────────────────────────── */
function setupChat() {
  if (chatSetup) return; chatSetup = true;
  document.getElementById('censorBtn')?.addEventListener('click', () => {
    censored = !censored;
    const b = document.getElementById('censorBtn');
    b.textContent = censored ? 'CENSOR ON' : 'CENSOR OFF';
    b.classList.toggle('is-active', censored);
    loadChat(true);
  });
  document.getElementById('chatFeed')?.addEventListener('scroll', () => {
    const f = document.getElementById('chatFeed');
    scrollLocked = f.scrollTop + f.clientHeight < f.scrollHeight - 60;
  });
}

function nickColor(s) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = ((h << 5) - h) + s.charCodeAt(i);
  return ['#00FF00','#00EE00','#00DD00','#00CC00','#00BB00'][Math.abs(h) % 5];
}

function norm(s) {
  return String(s).toLowerCase()
    .normalize('NFKD').replace(/[\u0300-\u036f]/g,'')
    .replace(/[@4]/g,'a').replace(/[0o]/g,'o').replace(/[13]/g,'i').replace(/5/g,'s')
    .replace(/(.)\1{2,}/g,'$1$1').replace(/[^a-z0-9]/g,'');
}
const BAD = new Set([
  'kurv','kund','pizd','cura','prdel','hovn','hovad','srat','srac',
  'kokot','mrd','zmrd','jeb','debil','idiot','svin','blbec','blbost',
  'pica','picu','pici','pico','picus','pichat','tvl','tyvol','vole',
  'devk','defk','napicu','dopici','doprdele','vprdeli',
  'fuck','shit','bitch','asshole','cunt','cock','moron','noob',
].map(norm));

function censor(text) {
  if (!censored) return text;
  return String(text).replace(/\S+/g, tok => {
    const n = norm(tok); if (!n) return tok;
    for (const b of BAD) if (n === b || n.includes(b)) return tok.replace(/[A-Za-z0-9\u00C0-\u024F]/g,'*');
    return tok;
  });
}

async function loadChat(force = false) {
  if (!authToken) return;
  try {
    const res = await fetch(API_CHAT, { headers: authHdr(authToken), signal: AbortSignal.timeout(7000) });
    if (res.status === 401) { sessionExpired(); return; }
    if (!res.ok) { document.getElementById('chatFeed').textContent = '[ERROR ' + res.status + ' — retrying]'; return; }

    const data = await res.json();
    if (!Array.isArray(data)) return;
    if (!force && JSON.stringify(data) === JSON.stringify(lastData)) return;
    lastData = data;

    const feed = document.getElementById('chatFeed');
    feed.innerHTML = '';
    for (const line of data) {
      if (line.startsWith('=== DAY ')) {
        const d = document.createElement('div'); d.className = 'sep day';
        d.textContent = line.replace(/^=== | ===$/, ''); feed.appendChild(d); continue;
      }
      if (line.startsWith('--- MAP ')) {
        const d = document.createElement('div'); d.className = 'sep map';
        d.textContent = line.replace(/^--- | ---$/, ''); feed.appendChild(d); continue;
      }
      const colon = line.indexOf(':');
      const nick = colon !== -1 ? line.slice(0, colon) : '???';
      const text = censor(colon !== -1 ? line.slice(colon + 1).trim() : line);
      const row = document.createElement('div'); row.className = 'msg';
      const nSpan = document.createElement('span'); nSpan.className = 'nick'; nSpan.style.color = nickColor(nick); nSpan.textContent = nick + ':';
      const tSpan = document.createElement('span'); tSpan.className = 'txt'; tSpan.textContent = text;
      row.appendChild(nSpan); row.appendChild(tSpan); feed.appendChild(row);
    }
    if (!scrollLocked) setTimeout(() => { feed.scrollTop = feed.scrollHeight; }, 30);

  } catch (err) {
    const msg = err?.name === 'AbortError' ? 'timeout' : (err?.message ?? String(err));
    const feed = document.getElementById('chatFeed');
    if (!lastData?.length) { feed.textContent = '[CONNECTION ERROR — retrying] (' + msg + ')'; return; }
    feed.querySelectorAll('.notice').forEach(n => n.remove());
    const notice = document.createElement('div'); notice.className = 'sep map notice';
    notice.textContent = '[CONNECTION ERROR — retrying] (' + msg + ')'; feed.appendChild(notice);
  }
}

document.getElementById('loginForm')?.addEventListener('submit', handleLogin);
</script>
